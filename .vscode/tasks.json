{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Gerar PDF CAIXA",
      "type": "shell",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\export-pdf.ps1",
        "-OutputFile",
        "pdf\\matriz_produto_unb_gelos_corrigido.pdf"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}